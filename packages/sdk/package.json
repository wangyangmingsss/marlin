{
  "name": "@marlinfi/sdk",
  "version": "1.0.0",
  "description": "TypeScript SDK for Marlin — stablecoin billing on Solana",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": { "import": "./dist/index.mjs", "require": "./dist/index.js", "types": "./dist/index.d.ts" },
    "./react": { "import": "./dist/react/index.mjs", "require": "./dist/react/index.js", "types": "./dist/react/index.d.ts" },
    "./confidential": { "import": "./dist/confidential/index.mjs", "require": "./dist/confidential/index.js", "types": "./dist/confidential/index.d.ts" }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "@noble/hashes": "^1.4.0",
    "@solana/web3.js": "^1.91.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "tsup": "^8.1.0",
    "vitest": "^1.6.0",
    "react": "^18.3.0",
    "@types/react": "^18.3.0",
    "@types/node": "^20.14.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true }
  },
  "files": ["dist"],
  "license": "MIT",
  "publishConfig": { "access": "public", "registry": "https://registry.npmjs.org/" },
  "repository": { "type": "git", "url": "https://github.com/wangyangmingsss/marlin.git", "directory": "packages/sdk" },
  "keywords": ["solana", "stablecoin", "billing", "invoices", "subscriptions", "usdc", "pyusd", "payments"]
}
