# Solana
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
NEXT_PUBLIC_SOLANA_RPC_URL=$SOLANA_RPC_URL
NEXT_PUBLIC_SOLANA_CLUSTER=$SOLANA_CLUSTER
MARLIN_PROGRAM_ID=MRLNxMrRgKMFnHEuJPsWnbDzDRKdNHvisijd7Gg6MjZ
NEXT_PUBLIC_MARLIN_PROGRAM_ID=$MARLIN_PROGRAM_ID
PROTOCOL_FEE_RECEIVER=HpwaQ1H2qqCs8a7ZEeq8s8Hm9qUvJnLvWTc6vXsbRFzT

# Mints
NEXT_PUBLIC_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
NEXT_PUBLIC_PYUSD_MINT=
NEXT_PUBLIC_USDG_MINT=

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/marlin
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/marlin

# Auth
JWT_SECRET=your-64-char-random-secret-here
SIWS_DOMAIN=marlin.fi
SESSION_COOKIE_NAME=marlin_session
SESSION_DAYS=7

# Helius
HELIUS_API_KEY=YOUR_HELIUS_API_KEY
HELIUS_WEBHOOK_SECRET=
PUBLIC_INDEXER_URL=https://indexer.marlin.fi

# Redis (Upstash)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Email
RESEND_API_KEY=
EMAIL_FROM_INVOICES=invoices@marlin.fi
EMAIL_FROM_NOREPLY=noreply@marlin.fi

# Cron Worker
CHARGER_PRIVATE_KEY=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_CHECKOUT_URL=http://localhost:3001
NEXT_PUBLIC_WIDGET_URL=http://localhost:3002
NEXT_PUBLIC_DOCS_URL=http://localhost:3003

# Observability
SENTRY_DSN=
LOG_LEVEL=info

# Feature flags
ENABLE_SUBSCRIPTION_AUTO_CHARGE=true
ENABLE_API_KEYS=true
ENABLE_WEBHOOKS=true
